{
  "name": "ai-foundry-agent-inspector",
  "displayName": "AI Foundry Agent Inspector",
  "description": "Visualize and debug Azure AI Foundry Agent Service runs directly in VS Code",
  "version": "0.1.0",
  "publisher": "jubinsoni",
  "icon": "images/icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/jubins/ai-foundry-agent-inspector"
  },
  "homepage": "https://github.com/jubins/ai-foundry-agent-inspector#readme",
  "bugs": {
    "url": "https://github.com/jubins/ai-foundry-agent-inspector/issues"
  },
  "license": "MIT",
  "galleryBanner": {
    "color": "#0078D4",
    "theme": "dark"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "Other",
    "Debuggers"
  ],
  "keywords": [
    "azure",
    "ai",
    "foundry",
    "agent",
    "trace",
    "debug",
    "llm",
    "openai"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "viewsContainers": {
      "activitybar": [
        {
          "id": "foundryInspector",
          "title": "AI Foundry Inspector",
          "icon": "images/icon-sidebar.svg"
        }
      ]
    },
    "views": {
      "foundryInspector": [
        {
          "id": "foundryInspector.sidebar",
          "name": "AI Foundry Inspector",
          "icon": "images/icon-sidebar.svg"
        }
      ]
    },
    "commands": [
      {
        "command": "foundryTrace.connect",
        "title": "Foundry Trace: Connect to Project"
      },
      {
        "command": "foundryTrace.listRuns",
        "title": "Foundry Trace: List Recent Runs"
      },
      {
        "command": "foundryTrace.setApiKey",
        "title": "Foundry Trace: Set API Key"
      },
      {
        "command": "foundryTrace.clearApiKey",
        "title": "Foundry Trace: Clear API Key"
      },
      {
        "command": "foundryTrace.showTrace",
        "title": "Foundry Trace: Show Trace"
      },
      {
        "command": "foundryInspector.openOnboarding",
        "title": "AI Foundry: Setup / Configure",
        "icon": "$(gear)"
      },
      {
        "command": "foundryInspector.refresh",
        "title": "AI Foundry: Refresh",
        "icon": "$(refresh)"
      },
      {
        "command": "foundryInspector.openConversation",
        "title": "AI Foundry: Open Conversation"
      },
      {
        "command": "foundryInspector.openResponse",
        "title": "AI Foundry: Open Response"
      },
      {
        "command": "foundryInspector.addConversation",
        "title": "AI Foundry: Add Conversation ID",
        "icon": "$(add)"
      },
      {
        "command": "foundryInspector.addResponse",
        "title": "AI Foundry: Add Response ID",
        "icon": "$(add)"
      },
      {
        "command": "foundryInspector.deleteResponse",
        "title": "AI Foundry: Delete Response",
        "icon": "$(trash)"
      }
    ],
    "menus": {
      "view/title": [
        {
          "command": "foundryInspector.refresh",
          "when": "view == foundryInspector.sidebar",
          "group": "navigation"
        },
        {
          "command": "foundryInspector.openOnboarding",
          "when": "view == foundryInspector.sidebar",
          "group": "navigation"
        }
      ],
      "view/item/context": [
        {
          "command": "foundryInspector.addConversation",
          "when": "view == foundryInspector.sidebar && viewItem == section-conversations",
          "group": "inline"
        },
        {
          "command": "foundryInspector.addResponse",
          "when": "view == foundryInspector.sidebar && viewItem == section-responses",
          "group": "inline"
        },
        {
          "command": "foundryInspector.deleteResponse",
          "when": "view == foundryInspector.sidebar && viewItem == response",
          "group": "inline"
        }
      ]
    },
    "configuration": {
      "title": "AI Foundry Agent Inspector",
      "properties": {
        "aiFoundryAgentInspector.projectEndpoint": {
          "type": "string",
          "default": "",
          "markdownDescription": "Your Azure AI Foundry project endpoint URL (e.g. `https://<hub>.services.ai.azure.com/api/projects/<project>`)"
        },
        "aiFoundryAgentInspector.authMethod": {
          "type": "string",
          "enum": [
            "entraId",
            "apiKey"
          ],
          "enumDescriptions": [
            "Use Azure DefaultAzureCredential (Entra ID / managed identity / az login)",
            "Use an API key stored securely in VS Code SecretStorage"
          ],
          "default": "entraId",
          "description": "Authentication method for connecting to your Foundry project"
        },
        "aiFoundryAgentInspector.maxRunsToList": {
          "type": "number",
          "default": 20,
          "minimum": 1,
          "maximum": 100,
          "description": "Maximum number of recent runs to fetch when listing runs"
        },
        "aiFoundryAgentInspector.responseIds": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "markdownDescription": "List of response IDs (`resp_...`) tracked in the sidebar. Find these in the Foundry portal Agents → your agent → Traces tab."
        },
        "aiFoundryAgentInspector.conversationIds": {
          "type": "array",
          "items": { "type": "string" },
          "default": [],
          "markdownDescription": "List of conversation IDs (`conv_...`) tracked in the sidebar. These are extracted automatically from saved responses, or can be added manually."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.6",
    "@types/node": "18.x",
    "@types/vscode": "^1.85.0",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "@vscode/test-cli": "^0.0.6",
    "@vscode/test-electron": "^2.3.8",
    "eslint": "^8.56.0",
    "typescript": "^5.3.3"
  },
  "dependencies": {
    "@azure/ai-projects": "^2.2.0",
    "@azure/identity": "^4.13.1"
  }
}
